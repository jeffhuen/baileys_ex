# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
baileys_ex-*.tar

# Reference source code (large, not ours)
/dev/reference/

# Agent scratch files (working memory, not committed)
/dev/implementation_plan/scratch/

# Compiled NIF binaries (built by mix compile)
/priv/native/

# Rust build artifacts
/native/baileys_nif/target/

# macOS
.DS_Store

# Local git worktrees
.worktrees/

# Local Claude worktree mirrors
/.claude/worktrees/

# Local trace/debug outputs
/trace_auth_info*/
/trace-wire*.log
/trace-qr*.txt
/trace-qr*.html
